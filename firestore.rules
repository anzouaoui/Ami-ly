rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── users/{uid} ──────────────────────────────────────────────────────────
    // Source de vérité : email, rôle, isPro, isProfileComplete.
    // Accessible uniquement par son propriétaire.
    match /users/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    // ── parents/{uid} ────────────────────────────────────────────────────────
    // Profil étendu du parent.
    //   Lecture : tout utilisateur authentifié
    //             (les assmats peuvent lire le profil d'une famille).
    //   Écriture : uniquement le propriétaire.
    match /parents/{uid} {
      allow read:  if isAuth();
      allow write: if isAuth() && isOwner(uid);

      // ── parents/{uid}/children/{childId} ──────────────────────────────────
      // Sous-collection des enfants du parent.
      //   Lecture : tout utilisateur authentifié
      //             (l'assmat a besoin de connaître les enfants qu'elle garde).
      //   Écriture : uniquement le propriétaire (le parent).
      match /children/{childId} {
        allow read:  if isAuth();
        allow write: if isAuth() && isOwner(uid);
      }

      // ── parents/{uid}/favorites/{assmatUid} ───────────────────────────────
      // Assmats mises en favori par ce parent.
      //   Lecture/Écriture : uniquement le propriétaire.
      match /favorites/{assmatUid} {
        allow read, write: if isAuth() && isOwner(uid);
      }
    }

    // ── assmats/{uid} ────────────────────────────────────────────────────────
    // Profil étendu de l'assistante maternelle.
    //   Lecture : tout utilisateur authentifié
    //             (les parents peuvent chercher des assmats disponibles).
    //   Écriture : uniquement le propriétaire.
    match /assmats/{uid} {
      allow read:  if isAuth();
      allow write: if isAuth() && isOwner(uid);
    }

    // ── conversations/{convId} ───────────────────────────────────────────────
    // Fil de discussion entre un parent et une assmat.
    //   convId = "${parentUid}_${assmatUid}" (déterministe).
    //   Lecture/Écriture : uniquement le parent ou l'assmat de la conversation.
    match /conversations/{convId} {
      function isParticipant() {
        return isAuth() && (
          resource == null ||
          request.auth.uid == resource.data.parentUid ||
          request.auth.uid == resource.data.assmatUid
        );
      }

      function isParticipantOnCreate() {
        let data = request.resource.data;
        return isAuth() && (
          request.auth.uid == data.parentUid ||
          request.auth.uid == data.assmatUid
        );
      }

      allow read: if isParticipant();
      allow create: if isParticipantOnCreate();
      allow update: if isParticipant();
      allow delete: if false;

      // ── conversations/{convId}/messages/{msgId} ────────────────────────────
      // Messages du fil.
      //   Lecture/Écriture : uniquement les participants de la conversation parente.
      match /messages/{msgId} {
        function convExists() {
          return exists(/databases/$(database)/documents/conversations/$(convId));
        }

        function convData() {
          return get(/databases/$(database)/documents/conversations/$(convId)).data;
        }

        function isConvParticipant() {
          return isAuth() &&
            convExists() && (
              request.auth.uid == convData().parentUid ||
              request.auth.uid == convData().assmatUid
            );
        }

        allow read, create: if isConvParticipant();
        allow update: if isConvParticipant();
        allow delete: if false;
      }
    }

    // ── contracts/{contractId} ────────────────────────────────────────────────
    // Contrat d'engagement réciproque entre un parent et une assmat.
    //   Lecture : le parent ou l'assmat concerné.
    //   Création : tout utilisateur authentifié.
    //   Mise à jour : le parent ou l'assmat concerné.
    match /contracts/{contractId} {
      function isParticipantOnCreate() {
        let data = request.resource.data;
        return isAuth() && (
          request.auth.uid == data.parentUid ||
          request.auth.uid == data.assmatUid
        );
      }

      function isParticipant() {
        return isAuth() && (
          resource.data.parentUid == request.auth.uid ||
          resource.data.assmatUid == request.auth.uid
        );
      }

      allow read:   if isParticipant();
      allow create: if isParticipantOnCreate();
      allow update: if isParticipant();
      allow delete: if false;

      // ── contracts/{contractId}/signatures/{signatureId} ────────────────────
      // Piste d'audit des signatures (parent puis assmat).
      match /signatures/{signatureId} {
        function isContractParticipant() {
          return isAuth() &&
            exists(/databases/$(database)/documents/contracts/$(contractId)) && (
            request.auth.uid ==
              get(/databases/$(database)/documents/contracts/$(contractId)).data.parentUid ||
            request.auth.uid ==
              get(/databases/$(database)/documents/contracts/$(contractId)).data.assmatUid
          );
        }
        allow read, create: if isContractParticipant();
        allow update, delete: if false;
      }
    }

    // ── Blocage par défaut ───────────────────────────────────────────────────
    // Toute collection non listée ci-dessus est refusée.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
